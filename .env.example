# ============================================================
# BaP Framework — Plantilla de variables de entorno
# ============================================================
# Copia este archivo como `.env` y completa los valores con
# las credenciales reales de tu proyecto Firebase.
# El archivo `.env` está en .gitignore y NUNCA debe subirse a Git.
# ============================================================

# Firebase Config
# Los nombres siguen la convención estándar del objeto de configuración de Firebase.
# Obtén estos valores en: Consola Firebase → Configuración del proyecto → Tus apps
apiKey=
authDomain=
databaseURL=
projectId=
storageBucket=
messagingSenderId=
appId=
measurementId=

# Control de disponibilidad de Firebase
# false = entorno local (sin Firebase), true = producción
FIREBASE_AVAILABLE=

# reCAPTCHA / App Check
# Obtén el Site Key en: https://console.cloud.google.com → reCAPTCHA Enterprise
RECAPTCHA_ID=
RECAPTCHA_NAME=
